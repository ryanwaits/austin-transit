POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=austintransit
POSTGRES_PASSWORD=austintransit
POSTGRES_DB=austintransit
# CapMetro (Austin) GTFS-RT + static feeds, hosted on data.texas.gov.
# Slugs verified live against the Socrata catalog (data.texas.gov/api/catalog/v1?q=GTFS).
GTFS_RT_VEHICLE_POSITIONS_URL=https://data.texas.gov/download/eiei-9rpf/application%2Foctet-stream
GTFS_RT_TRIP_UPDATES_URL=https://data.texas.gov/download/rmk2-acnw/application%2Foctet-stream
GTFS_STATIC_URL=https://data.texas.gov/download/r4v4-vz24/application%2Fzip
POLL_INTERVAL_MS=30000
# Optional: Cloudflare R2 archive of raw protobuf feeds (the forensic record of
# record). Leave unset to disable archiving. R2_ACCOUNT_ID derives the endpoint;
# alternatively set R2_ENDPOINT directly.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=austin-transit-feeds
